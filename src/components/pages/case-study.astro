---
import BaseHead from '@/components/BaseHead.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import LinkButton from '@/components/LinkButton.astro'
import Link from '@/components/icons/Link.astro'
import { Picture } from 'astro:assets'

import { getI18N } from '@/i18n'
import { getLangFromUrl } from '@/i18n/utils'
import { defaultLang } from '@/i18n/ui'
import { ClientRouter } from 'astro:transitions'
import { getTagClass } from '@/lib/tags'

interface Props {
  entry: {
    data: {
      title: string
      description: string
      projectSlug: string
      language: string
      client?: string
      year?: string
      role?: string
      cover?: ImageMetadata
      stack?: string[]
    }
  }
  projectLink?: string
}

const { entry, projectLink } = Astro.props
const { data } = entry
const { currentLocale } = Astro
const i18n = getI18N({ currentLocale })
const lang = getLangFromUrl(Astro.url)

const backHref =
  currentLocale === defaultLang ? '/#projects' : `/${currentLocale}/#projects`
---

<html
  lang={lang}
  class='scroll-py-24 scroll-smooth scrollbar scrollbar-track-background scrollbar-thumb-foreground motion-reduce:scroll-auto'
>
  <head>
    <BaseHead
      title={`${data.title} | Diego de Sousa`}
      description={data.description}
      image={data.cover?.src}
      type='article'
    />
    <ClientRouter />

    <style is:global>
      .case-study-prose h2 {
        font-size: 1.75rem !important;
        font-weight: 800 !important;
        margin-top: 3rem !important;
        margin-bottom: 1rem !important;
        line-height: 1.3 !important;
        letter-spacing: -0.01em;
        color: hsl(var(--foreground));
        padding-bottom: 0.5rem;
        border-bottom: 2px solid hsl(var(--accent) / 0.2);
      }
      .case-study-prose h3 {
        font-size: 1.35rem !important;
        font-weight: 700 !important;
        margin-top: 2rem !important;
        margin-bottom: 0.75rem !important;
        line-height: 1.4 !important;
        color: hsl(var(--foreground));
      }
      .case-study-prose h4 {
        font-size: 1.125rem !important;
        font-weight: 700 !important;
        margin-top: 1.5rem !important;
        margin-bottom: 0.5rem !important;
        line-height: 1.4 !important;
        color: hsl(var(--foreground));
      }
      @media (min-width: 1536px) {
        .case-study-prose h2 {
          font-size: 2.25rem !important;
        }
        .case-study-prose h3 {
          font-size: 1.625rem !important;
        }
        .case-study-prose h4 {
          font-size: 1.25rem !important;
        }
      }
      .case-study-prose p {
        margin-bottom: 1.5rem !important;
        line-height: 1.8 !important;
      }
      .case-study-prose ul {
        list-style: disc !important;
        padding-left: 2rem !important;
        margin-bottom: 1.5rem !important;
      }
      .case-study-prose ol {
        list-style: decimal !important;
        padding-left: 2rem !important;
        margin-bottom: 1.5rem !important;
      }
      .case-study-prose li {
        margin-bottom: 0.5rem !important;
        line-height: 1.8 !important;
      }
      .case-study-prose li::marker {
        color: hsl(var(--accent));
      }
      .case-study-prose a {
        color: hsl(var(--accent));
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .case-study-prose a:hover {
        opacity: 0.8;
      }
      .case-study-prose blockquote {
        border-left: 3px solid hsl(var(--accent));
        padding-left: 1rem;
        margin-bottom: 1.5rem;
        font-style: italic;
        color: hsl(var(--muted-foreground));
      }
      .case-study-prose strong {
        font-weight: 700 !important;
      }
      .case-study-prose code {
        font-family: 'Recursive Variable', monospace;
        font-size: 0.875em;
        background-color: hsl(var(--muted));
        padding: 0.125rem 0.375rem;
        border-radius: 0.25rem;
      }
      .case-study-prose pre {
        background-color: hsl(var(--muted));
        padding: 1rem;
        border-radius: 0.5rem;
        overflow-x: auto;
        margin-bottom: 1.5rem;
      }
      .case-study-prose pre code {
        background-color: transparent;
        padding: 0;
      }
      .case-study-prose img {
        border-radius: 0.5rem;
        margin-top: 1.5rem;
        margin-bottom: 1.5rem;
      }
      .case-study-prose hr {
        border-color: hsl(var(--border));
        margin-top: 2.5rem;
        margin-bottom: 2.5rem;
      }
      .case-study-prose table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.5rem;
      }
      .case-study-prose th,
      .case-study-prose td {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid hsl(var(--border));
        text-align: left;
      }
      .case-study-prose th {
        font-weight: 700 !important;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: hsl(var(--muted-foreground));
      }
    </style>
  </head>
  <body class='bg-background'>
    <Header />
    <main class='relative flex w-full flex-col bg-background'>
      <section class='px-6 pb-12 pt-24 md:px-12 md:pt-40'>
        <div class='mx-auto max-w-prose'>
          <nav>
            <a
              href={backHref}
              class='inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-accent'
            >
              &larr; {i18n.CASESTUDY.BACK_TO_PROJECTS}
            </a>
          </nav>

          <header class='mt-8'>
            <h1 class='text-balance text-3xl font-bold text-foreground md:text-4xl'>
              {data.title}
            </h1>

            {
              (data.client || data.year || data.role) && (
                <dl class='mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-muted-foreground'>
                  {data.client && (
                    <>
                      <dt class='font-semibold'>{i18n.CASESTUDY.CLIENT}</dt>
                      <dd>{data.client}</dd>
                    </>
                  )}
                  {data.year && (
                    <>
                      <dt class='font-semibold'>{i18n.CASESTUDY.YEAR}</dt>
                      <dd>{data.year}</dd>
                    </>
                  )}
                  {data.role && (
                    <>
                      <dt class='font-semibold'>{i18n.CASESTUDY.ROLE}</dt>
                      <dd>{data.role}</dd>
                    </>
                  )}
                </dl>
              )
            }
          </header>

          {
            data.cover && (
              <Picture
                src={data.cover}
                widths={[400, 800, 1200]}
                sizes='(min-width: 768px) 65ch, 100vw'
                alt={data.title}
                class='mt-8 w-full rounded-lg'
              />
            )
          }

          <article class='case-study-prose mt-12 text-foreground'>
            <slot />
          </article>

          {
            data.stack && data.stack.length > 0 && (
              <aside class='mt-12 border-t border-border pt-8'>
                <h2 class='mb-4 text-lg font-semibold text-foreground'>
                  {i18n.CASESTUDY.TECHNOLOGIES}
                </h2>
                <ul class='flex flex-wrap gap-2'>
                  {data.stack.map((tech: string) => (
                    <li class={`rounded-full px-3 py-1 text-sm ${getTagClass(tech)}`}>
                      {tech}
                    </li>
                  ))}
                </ul>
              </aside>
            )
          }

          {
            projectLink && (
              <aside class='mt-8 border-t border-border pt-8'>
                <LinkButton href={projectLink}>
                  <Link class='size-4' />
                  {i18n.CASESTUDY.VISIT_PROJECT}
                </LinkButton>
              </aside>
            )
          }
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
