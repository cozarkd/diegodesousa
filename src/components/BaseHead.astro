---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.

// Subset: weight (300-1000) + slant for italic. Drops MONO/CASL/CRSV axes (unused).
import '@fontsource-variable/recursive/standard.css'

import '@/styles/global.css'
import StructuredData from '@/components/StructuredData.astro'
import { defaultLang } from '@/i18n/ui'

interface Props {
  title: string
  description: string
  image?: string
  type?: 'website' | 'article'
  // Article-only metadata for JSON-LD
  pageData?: {
    title: string
    description: string
    image?: string
    year?: string
  }
  breadcrumbName?: string
  // For case studies: locales where this same content (same projectSlug) exists.
  // If omitted, defaults to all locales (suitable for landings/static pages).
  alternateLocales?: string[]
  // Path SUFFIX after the locale prefix (no leading slash needed). For landings:
  // empty string. For case studies: e.g. 'projects/floralia/'.
  // If omitted, falls back to Astro.url.pathname stripped of locale prefix.
  pathSuffix?: string
}

const SITE_URL = 'https://diegodesousa.com'
const ALL_LOCALES = ['es', 'en', 'gl', 'pt'] as const

const canonicalURL = new URL(Astro.url.pathname, Astro.site)

const {
  title,
  description,
  image = '/folio_duotono_bg2x.png',
  type = 'website',
  pageData,
  breadcrumbName,
  alternateLocales,
  pathSuffix
} = Astro.props

const umamiScriptUrl = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID

// --- og:locale mapping (Facebook standard codes) ---
const ogLocaleMap: Record<string, string> = {
  es: 'es_ES',
  en: 'en_US',
  gl: 'gl_ES',
  pt: 'pt_PT'
}

const currentLocale = (Astro.currentLocale ?? defaultLang) as string
const ogLocale = ogLocaleMap[currentLocale] ?? ogLocaleMap[defaultLang]
const otherLocales = ALL_LOCALES.filter((l) => l !== currentLocale)

// --- hreflang alternates ---
// Compute the suffix (path after the locale prefix). For default locale there is no
// prefix, so we use the full pathname (minus leading slash). For other locales we
// strip '/<locale>/' from the start.
function computeSuffix(pathname: string, locale: string): string {
  if (locale === defaultLang) {
    return pathname.replace(/^\//, '')
  }
  const prefix = `/${locale}/`
  if (pathname.startsWith(prefix)) {
    return pathname.slice(prefix.length)
  }
  // Edge: '/<locale>' with no trailing slash
  if (pathname === `/${locale}`) return ''
  return pathname.replace(/^\//, '')
}

const resolvedSuffix =
  pathSuffix !== undefined
    ? pathSuffix.replace(/^\//, '')
    : computeSuffix(Astro.url.pathname, currentLocale)

// Locales eligible for alternates. Default: all four. Overridable for case studies.
const eligibleLocales = alternateLocales ?? [...ALL_LOCALES]

function buildLocaleUrl(locale: string, suffix: string): string {
  if (locale === defaultLang) {
    return `${SITE_URL}/${suffix}`
  }
  return `${SITE_URL}/${locale}/${suffix}`
}

const hreflangEntries = eligibleLocales.map((locale) => ({
  hreflang: locale,
  href: buildLocaleUrl(locale, resolvedSuffix)
}))

// x-default points to the default locale URL (when it's eligible)
const xDefaultHref = eligibleLocales.includes(defaultLang)
  ? buildLocaleUrl(defaultLang, resolvedSuffix)
  : null
---

<!-- Global Metadata -->
<meta charset='utf-8' />
<meta name='viewport' content='width=device-width,initial-scale=1' />

<meta name='generator' content={Astro.generator} />

<!-- Seasonal Theme Script - runs immediately to prevent FOUC -->
<script is:inline>
  (function() {
    const now = new Date();
    const month = now.getMonth() + 1;
    const day = now.getDate();

    let season = 'winter'; // default

    // Christmas
    if ((month === 12 && day >= 1) || (month === 1 && day <= 6)) {
      season = 'christmas';
    }
    // Halloween
    else if (month === 10 && day === 31) {
      season = 'halloween';
    }
    // Winter
    else if ((month === 12 && day >= 21) || month === 1 || month === 2 || (month === 3 && day < 20)) {
      season = 'winter';
    }
    // Spring
    else if ((month === 3 && day >= 20) || month === 4 || month === 5 || (month === 6 && day < 21)) {
      season = 'spring';
    }
    // Summer
    else if ((month === 6 && day >= 21) || month === 7 || month === 8 || (month === 9 && day < 23)) {
      season = 'summer';
    }
    // Autumn
    else if ((month === 9 && day >= 23) || month === 10 || month === 11 || (month === 12 && day < 21)) {
      season = 'autumn';
    }

    document.documentElement.setAttribute('data-season', season);
  })();
</script>

<!-- Font preloads -->
<!-- <link
  rel="preload"
  href="/fonts/JetBrainsMono-VariableFont_wght.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/> -->

<!-- Canonical URL -->
<link rel='canonical' href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name='title' content={title} />
<meta name='description' content={description} />

<!-- Open Graph / Facebook -->
<meta property='og:type' content={type} />
<meta property='og:url' content={Astro.url} />
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:image' content={new URL(image, Astro.url)} />
<meta property='og:locale' content={ogLocale} />
{
  otherLocales.map((l) => (
    <meta property='og:locale:alternate' content={ogLocaleMap[l]} />
  ))
}

<!-- hreflang alternates -->
{
  hreflangEntries.map(({ hreflang, href }) => (
    <link rel='alternate' hreflang={hreflang} href={href} />
  ))
}
{xDefaultHref && <link rel='alternate' hreflang='x-default' href={xDefaultHref} />}

<!-- Twitter -->
<meta property='twitter:card' content='summary_large_image' />
<meta property='twitter:url' content={Astro.url} />
<meta property='twitter:title' content={title} />
<meta property='twitter:description' content={description} />
<meta property='twitter:image' content={new URL(image, Astro.url)} />

<link rel='apple-touch-icon' sizes='180x180' href='/apple-touch-icon.png' />
<link rel='icon' type='image/png' sizes='32x32' href='/favicon-32x32.png' />
<link rel='icon' type='image/png' sizes='16x16' href='/favicon-16x16.png' />
<link rel='manifest' href='/site.webmanifest' />
<link rel='mask-icon' href='/safari-pinned-tab.svg' color='#3a3a3a' />
<meta name='msapplication-TileColor' content='#da532c' />
<meta name='theme-color' content='#ffffff' />

<!-- JSON-LD structured data -->
<StructuredData
  type={type}
  pageData={pageData}
  breadcrumbName={breadcrumbName}
/>

<!-- Umami Analytics (production only, restricted to diegodesousa.com) -->
{
  import.meta.env.PROD && umamiScriptUrl && umamiWebsiteId && (
    <script
      is:inline
      defer
      src={umamiScriptUrl}
      data-website-id={umamiWebsiteId}
      data-domains='diegodesousa.com,www.diegodesousa.com'
      data-do-not-track='true'
    />
  )
}

<!-- The next line enables the indexing by robots on the page level -->
<meta name='robots' content='index, follow' />

<!-- Sitemap -->
<link rel='sitemap' href='/sitemap-index.xml' />
